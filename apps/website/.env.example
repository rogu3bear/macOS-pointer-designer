# WindowDrop Environment Configuration
# Copy to .env and fill in values

# Server port
PORT=3410

# Logging level
RUST_LOG=info

# Email (Resend)
RESEND_API_KEY=

# Cloudflare deploy
# Use a repo-scoped API token for non-interactive Cloudflare deploys.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
#
# Local tunnel ingress only needs the tunnel values below.
TUNNEL_ID=
TUNNEL_TOKEN=
