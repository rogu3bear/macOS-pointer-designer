# WindowDrop Server Runtime Configuration
# Copy to .env and fill in values.

# Server port
PORT=3410

# Logging level
RUST_LOG=info

# Stripe checkout (required for web licensing)
STRIPE_API_KEY=sk_live_xxx
EXPECTED_STRIPE_ACCOUNT_ID=acct_xxx

# License signing (required for web licensing)
WINDOWDROP_WEB_LICENSE_PRIVATE_KEY_PATH=/Users/you/.windowdrop-keys/windowdrop-web-license-private.pem
WINDOWDROP_SITE_URL=https://windowdrop.pro

# Email delivery for license keys (Resend)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=WindowDrop <licenses@windowdrop.pro>

# Download URL (R2 CDN — overrides compiled-in default)
WINDOWDROP_DMG_URL=https://releases.windowdrop.pro/WindowDrop-1.0.4.dmg

# Lifetime CTA mode: "web" enables Stripe checkout, "in-app" routes to App Store
SITE_LIFETIME_MODE=web

# Cloudflare Tunnel
# The Axum runtime only needs tunnel values here.
# Cloudflare API deploy auth belongs to the root windowdrop Pages deploy.
TUNNEL_ID=
TUNNEL_TOKEN=
