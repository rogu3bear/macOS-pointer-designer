# WindowDrop Server Runtime Configuration
# Copy to .env and fill in values.

# Server port
PORT=3410

# Logging level
RUST_LOG=info

# Stripe checkout (required for web licensing)
STRIPE_API_KEY=sk_live_xxx
EXPECTED_STRIPE_ACCOUNT_ID=acct_xxx

# License signing (required for web licensing)
WINDOWDROP_WEB_LICENSE_PRIVATE_KEY_PATH=/Users/you/.windowdrop-keys/windowdrop-web-license-private.pem
WINDOWDROP_SITE_URL=https://windowdrop.pro

# Email delivery for license keys (Resend)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=WindowDrop <licenses@windowdrop.pro>

# Public release metadata.
# Defaults live in ops/release-env.sh and currently point to rogu3bear/windowdrop v1.0.1.
# Override only after a newer public release is published and verified.
WINDOWDROP_RELEASE_REPO=rogu3bear/windowdrop
WINDOWDROP_RELEASE_VERSION=1.0.1
WINDOWDROP_RELEASE_TAG=v1.0.1
WINDOWDROP_RELEASE_URL=https://github.com/rogu3bear/windowdrop/releases/tag/v1.0.1
WINDOWDROP_DMG_URL=https://github.com/rogu3bear/windowdrop/releases/download/v1.0.1/WindowDrop-1.0.1.dmg
WINDOWDROP_ZIP_URL=https://github.com/rogu3bear/windowdrop/releases/download/v1.0.1/WindowDrop-1.0.1.zip
WINDOWDROP_CHECKSUMS_URL=https://github.com/rogu3bear/windowdrop/releases/download/v1.0.1/WindowDrop-1.0.1-checksums.txt

# Lifetime CTA mode: "web" enables Stripe checkout, "in-app" routes to download/app purchase flow.
SITE_LIFETIME_MODE=in-app

# Cloudflare Tunnel
# The Axum runtime only needs tunnel values here.
# Cloudflare API deploy auth belongs to the root windowdrop Pages deploy.
TUNNEL_ID=
TUNNEL_TOKEN=
